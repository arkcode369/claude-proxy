# Port to listen on
PORT=1111

# Upstream Claude API endpoint (keep this secret!)
UPSTREAM_URL=https://your-upstream-endpoint.com/api/analyze

# Force all requests to use this model (recommended!)
# Upstream only supports specific models — set this to avoid "empty response" errors
# Leave empty to pass model name as-is from the client
FORCE_MODEL=claude-haiku-4-5-20251001

# Comma-separated list of valid API keys for protecting your proxy
# Example: API_KEYS=mykey123,anotherkey456
API_KEYS=your-secret-api-key-here
